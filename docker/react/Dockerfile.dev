# syntax=docker/dockerfile:1
# ============================================================
# TEMPLATE: Dockerfile — React Development (hot reload)
# WHEN TO USE: Local development only — NOT for production
# PREREQUISITES: React project with package.json
# SECRETS NEEDED: None
# WHAT TO CHANGE: Lines marked with # <-- CHANGE THIS
# RELATED FILES: docker/react/Dockerfile (production)
# MATURITY: Stable
# ============================================================

FROM node:22-alpine
WORKDIR /app

# Install dependencies (full dev deps for hot reload)
COPY package*.json ./
RUN npm install

# Source is bind-mounted at runtime for hot reload — this COPY is a fallback
COPY . .

# Create non-root user for development
RUN addgroup -S appgroup && adduser -S appuser -G appgroup && \
    chown -R appuser:appgroup /app
USER appuser

EXPOSE 3000                                                 # <-- CHANGE THIS: your dev server port
CMD ["npm", "start"]
