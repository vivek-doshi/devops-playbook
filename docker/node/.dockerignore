# ============================================================
# .dockerignore — Node.js (Express / Next.js)
# Keeps build context lean by excluding local install
# artefacts, test output, and editor metadata.
# ============================================================

# Local dependency installs (restored inside the image via npm ci)
node_modules/

# Build outputs
dist/
.next/
out/
build/

# Test and coverage artefacts
coverage/
.nyc_output/
*.lcov

# Environment files (must be injected at runtime, not baked in)
.env
.env.*
.env.local
.env.*.local

# Version control
.git/
.gitignore
.gitattributes
.github/

# IDE / editor metadata
.vscode/
.idea/
*.swp
*.swo

# Documentation and tooling
*.md
README*
LICENSE
docker-compose*.yml

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS artefacts
.DS_Store
Thumbs.db
